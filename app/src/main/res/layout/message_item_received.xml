<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/receivedRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingEnd="52dp"
    android:layout_marginBottom="6dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/receivedMessageProfilePic"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/circle_mask"
        android:scaleType="centerCrop" />

    <!-- Bubble + Time -->
    <LinearLayout
        android:id="@+id/receivedBubbleColumn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/receivedMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/message_bubble_received"
            android:fontFamily="@font/segoeui_regular"
            android:maxWidth="280dp"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="Hello"
            android:textColor="#1F241F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/receivedMessageTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            android:text="8:35 PM"
            android:textColor="#8A9387"
            android:textSize="10sp"
            android:alpha="0"
            android:visibility="gone"
            android:animateLayoutChanges="true"/>

    </LinearLayout>

</LinearLayout>