<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F5"
    android:focusableInTouchMode="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Home"
            android:textColor="#1E241F"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/segoeui_bold" />
    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Filter Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filterOfficial"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/filter_chip_unselected"
                    android:gravity="center"
                    android:minWidth="76dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Official"
                    android:textColor="#445046"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/filterDepartment"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/filter_chip_selected"
                    android:gravity="center"
                    android:minWidth="98dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Department"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Pinned Header -->
            <TextView
                android:id="@+id/pinnedHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Pinned Posts"
                android:textColor="#2A2F2A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Pinned Content -->
            <LinearLayout
                android:id="@+id/pinnedContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:id="@+id/pinnedCard"
                    android:layout_width="match_parent"
                    android:layout_height="164dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false"
                    app:strokeColor="#ECEEE8"
                    app:strokeWidth="1dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/pinnedPager"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:orientation="horizontal" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/pinnedDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Pinned Skeleton -->
            <LinearLayout
                android:id="@+id/pinnedSkeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="164dp"
                    android:background="@drawable/skeleton_block_rounded" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/skeleton_dot" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/skeleton_dot" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/skeleton_dot" />
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/pinnedEmptyCard"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#F1F3EE"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E7EAE3"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="No pinned posts yet"
                    android:textColor="#6D766B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <!-- Latest Header -->
            <LinearLayout
                android:id="@+id/latestHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/latestTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Latest Posts"
                    android:textColor="#2A2F2A"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="6dp"
                    android:text="View All"
                    android:textColor="#1F5A43"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Latest Content -->
            <LinearLayout
                android:id="@+id/latestSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/latestPostsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/home_post_item" />
            </LinearLayout>

            <!-- Latest Skeleton -->
            <LinearLayout
                android:id="@+id/latestSkeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/skeleton_block_rounded" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/skeleton_block_rounded" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/skeleton_block_rounded" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/latestEmptyCard"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#F1F3EE"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E7EAE3"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="No latest posts in the last 24 hours"
                    android:textColor="#6D766B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>